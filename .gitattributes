# Forcer LF pour tous les scripts shell (évite CRLF sur Windows)
gradlew           text eol=lf
*.sh              text eol=lf
*.gradle          text eol=lf
*.properties      text eol=lf
*.json            text eol=lf
*.xml             text eol=lf
*.js              text eol=lf
*.html            text eol=lf
*.md              text eol=lf

